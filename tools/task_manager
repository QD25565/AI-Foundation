#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""CLI wrapper for task_manager tool using universal adapter"""

# Configure logging FIRST, before any other imports (AI-first: clean output)
import logging
logging.basicConfig(level=logging.WARNING, format='%(message)s')
logging.getLogger().setLevel(logging.WARNING)
logging.getLogger('sentence_transformers').setLevel(logging.ERROR)
logging.getLogger('chromadb').setLevel(logging.ERROR)
logging.getLogger('transformers').setLevel(logging.ERROR)

import sys
import io
import os
from pathlib import Path

# Set instance-specific data directory
os.environ['AI_ID'] = 'claude-instance-2'
os.environ['MCP_DATA_DIR'] = str(Path(__file__).parent.parent / 'data')

# Fix Windows console encoding for emojis
if sys.platform == 'win32':
    sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8', errors='replace')
    sys.stderr = io.TextIOWrapper(sys.stderr.buffer, encoding='utf-8', errors='replace')

# Add tools directory to path
tools_dir = Path(__file__).parent
sys.path.insert(0, str(tools_dir))

# Import and configure universal adapter
from universal_adapter import CLIAdapter

if __name__ == '__main__':
    # Simple passthrough to universal adapter
    if len(sys.argv) == 1 or sys.argv[1] in ['-h', '--help', 'help']:
        adapter = CLIAdapter('task_manager')
        adapter.list_commands()
        sys.exit(0)

    command = sys.argv[1]

    # Parse remaining args as key-value pairs
    cmd_args = {}
    i = 2
    while i < len(sys.argv):
        if sys.argv[i].startswith('--'):
            key = sys.argv[i][2:]
            if i + 1 < len(sys.argv) and not sys.argv[i + 1].startswith('--'):
                value = sys.argv[i + 1]
                i += 2
            else:
                value = True
                i += 1
            cmd_args[key] = value
        else:
            # Treat as positional argument
            if 'task' not in cmd_args:
                cmd_args['task'] = sys.argv[i]
            i += 1

    adapter = CLIAdapter('task_manager')
    adapter.run(command, cmd_args)