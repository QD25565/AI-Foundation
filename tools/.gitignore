# AI-Foundation .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Data directories (contain user data, don't commit)
notebook_data/
teambook_data/
task_manager_data/
world_data/
*.duckdb
*.duckdb.wal
*.db

# User-specific files
ai_identity.txt
.env
*.log

# PostgreSQL
.pgpass

# Redis
dump.rdb

# ChromaDB vector storage
chroma_data/
*.index

# Vault encryption keys
vault_key.bin
.vault_key

# Temporary files
*.tmp
*.temp
*_temp_*.duckdb
temp/
tmp/

# Test outputs
test_output.txt
test_results.txt
test_results/
test_*.txt

# Test files (keep test scripts but ignore outputs)
# Note: test_rooms_10x.py is intentionally NOT ignored (it's a useful validation tool)

# Backups
*_backup*/
*.backup
*.bak

# OS
Thumbs.db
.DS_Store
desktop.ini

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Pytest
.pytest_cache/

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# Documentation builds
docs/_build/

# Distribution / packaging
.Python
*.manifest
*.spec

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.tox/
.nox/
.coverage
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/
