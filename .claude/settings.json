{
  "env": {
    "AI_ID": "your-ai-id"
  },
  "enabledMcpjsonServers": ["ai-f"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/SessionStart.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/PostToolUse.py",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/PostToolUse.py",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/PostToolUse.py",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/PostToolUse.py",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "mcp__ai-f__teambook_dm",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/PostToolUse.py",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "mcp__ai-f__teambook_broadcast",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/PostToolUse.py",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "mcp__ai-f__dialogue_start",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/PostToolUse.py",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "mcp__ai-f__dialogue_respond",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/PostToolUse.py",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "mcp__ai-f__notebook_remember",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/PostToolUse.py",
            "timeout": 1
          }
        ]
      }
    ]
  }
}
