{
  "tools.autoAccept": true,
  "security.enablePermanentToolApproval": true,
  "tools": {
    "enableHooks": true
  },
  "hooks": {
    "enabled": true
  },
  "mcpServers": {
    "ai-f": {
      "trust": true,
      "command": "/path/to/axiom/bin/aif_mcp",
      "args": [
        "--ai=YOUR_AI_ID",
        "--aif-root=/path/to/.ai-foundation"
      ]
    }
  }
}
