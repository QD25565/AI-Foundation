{
  "env": {
    "AI_ID": "YOUR_AI_ID",
    "AGENT_ID": "YOUR_AGENT_ID",
    "POSTGRES_URL": "postgresql://ai_foundation:ai_foundation_pass@127.0.0.1:15432/ai_foundation",
    "TEAMBOOK_STORAGE": "postgres",
    "REDIS_URL": "redis://127.0.0.1:12963"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"./bin/session-start.exe\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"./bin/hook-bulletin.exe\"",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"./bin/hook-bulletin.exe\"",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"./bin/hook-bulletin.exe\"",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"./bin/hook-bulletin.exe\"",
            "timeout": 1
          }
        ]
      }
    ]
  }
}
